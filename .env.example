# Copy this file to .env and fill in values for local development.
# .env is gitignored — never commit real secrets.

# --- Server ---
# Port the Express server listens on (default: 3000).
PORT=3000

# Public base URL of the deployment, returned by GET /config (default: http://localhost:3000).
SERVER_URL=http://localhost:3000

# Express session signing secret. REQUIRED in production — set a long random value.
# Falls back to an insecure dev-only default when unset.
SESSION_SECRET=

# Comma-separated CORS origin allowlist
# (e.g. https://ric3family.com,https://www.ric3family.com).
# When unset, the request origin is reflected (suitable for local dev only).
ALLOWED_ORIGINS=

# --- Database (MongoDB) ---
# Full Mongo connection string (default: mongodb://127.0.0.1:27017/).
DB_URL=mongodb://127.0.0.1:27017/

# --- Google Cloud Storage (image uploads) ---
# Target GCS bucket for profile / event / group / slideshow images.
BUCKET_NAME=

# GCP project id (only needed for local dev with a key file).
PROJECT_ID=

# Path to a GCP service-account key JSON file for local dev.
# When unset, Application Default Credentials (ADC) are used (e.g. on Cloud Run).
SECRET_KEY=
