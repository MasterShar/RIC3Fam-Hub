<!-- Events List -->
<div class="list-wrapper">
    <h3 class="list-header">Events</h3>
    {{#if currentUser.isAdmin}}
        <a href="/create-event">Create New Event</a>
    {{/if}}
    <dl id="game-list" class="list-of-all">
        {{#each events}}
            <dd class="search-result">
                <a href="/games/{{this._id}}">{{this.gameName}}</a>
            </dd>
        {{/each}}
    </dl>
</div>

<!--
<div class="event-image-container">
    <img src="https://storage.googleapis.com/family-frisbee-media/icons/eventHub.jpg" class="event-image" alt="Event flyer">
</div>

-->

{{#if currentUser.isAdmin}}
    {{> addToSlideshow route='events' isEventPage=true}}
{{/if}}

{{#if slideshowImages.length}}
    <h3 class="list-header">Picture Bar</h3>
{{/if}}

{{> showSlideshow}}